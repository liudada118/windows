{
  "name": "windoor-designer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @windoor/client dev",
    "dev:server": "pnpm --filter @windoor/server dev",
    "dev:all": "pnpm --parallel --filter @windoor/client --filter @windoor/server dev",
    "build": "pnpm --filter @windoor/shared build && pnpm --parallel --filter @windoor/client --filter @windoor/server build",
    "build:client": "pnpm --filter @windoor/shared build && pnpm --filter @windoor/client build",
    "build:server": "pnpm --filter @windoor/shared build && pnpm --filter @windoor/server build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "5.6.3"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af"
}